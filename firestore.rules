rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dados do site (logo, stats, equipe, serviços, depoimentos, contato)
    // Leitura pública (conteúdo do site), escrita apenas para admins autenticados
    match /siteData/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Projetos do portfólio
    // Leitura pública, escrita apenas para admins autenticados
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Mensagens de contato
    // Qualquer visitante pode CRIAR, apenas admins autenticados podem LER, ATUALIZAR e EXCLUIR
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
